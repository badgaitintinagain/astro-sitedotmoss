---
import LoginModal from './LoginModal';

// Check if user is logged in via cookie (Server-side)
const authCookie = Astro.cookies.get('auth_user');
let isAdmin = false;
try {
    if (authCookie) {
        const user = JSON.parse(authCookie.value);
        isAdmin = user.role === 'admin';
    }
} catch (e) {}
---
<nav class="h-14 flex md:hidden items-center justify-between z-50 fixed top-0 left-0 w-full border-b border-stone-200/80 bg-white/65 text-stone-800 backdrop-blur-xl shadow-[0_1px_0_rgba(255,255,255,0.75)]" x-data={`{ loginOpen: false, isLoggedIn: ${isAdmin} }`}>
    <!-- Login Modal Integration -->
    <div class="contents">
        <LoginModal client:load isOpen={false} onClose={() => {}} x-bind:isOpen="loginOpen" @close="loginOpen = false" />
    </div>

    <!-- Thin top line -->
    <div class="absolute left-0 top-0 w-full h-[2px] bg-white/40 flex">
        <div class="w-1/3 h-full bg-accent-primary/25"></div>
    </div>
    
    <div class="flex items-center h-full border-r border-stone-200 px-3 md:px-6">
        <div class="relative flex items-center justify-center w-8 h-8 mr-3 border border-stone-300 bg-white/70 shadow-inner">
            <img src="/favicon.ico" alt="Favicon" class="w-4 h-4 object-contain">
        </div>
        <div class="flex flex-col">
            <span class="font-mono font-semibold tracking-wide text-[11px] leading-none mb-0.5 text-stone-800">
                <a href="/">SITEDOTMOSS</a>
            </span>
        </div>
    </div>
    
    <div class="flex-1 flex justify-center h-full items-center px-4">
        <div class="hidden md:flex space-x-12 text-[11px] tracking-wide font-semibold text-stone-700">
            <a href="/" class="group relative flex items-center gap-2 hover:text-accent-primary transition-colors">
                <span>DASHBOARD</span>
            </a>
            <a href="/blog" class="group relative flex items-center gap-2 hover:text-accent-primary transition-colors">
                <span>BLOG ARCHIVE</span>
            </a>
        </div>
    </div>
    
    <div class="flex items-center h-full border-l border-stone-200 pl-3 md:pl-6 pr-4 text-stone-800">
        <button @click="quickOpen = true" class="relative group flex h-9 w-9 border border-stone-300 items-center justify-center bg-white/65 hover:bg-white hover:text-stone-900 transition-all shadow-[0_8px_20px_rgba(0,0,0,0.06)]" aria-label="Open quick settings">
            <i data-lucide="sliders-horizontal" class="w-5 h-5 transition-all duration-500 relative z-10"></i>
        </button>
    </div>
</nav>
