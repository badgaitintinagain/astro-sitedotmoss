---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import SpotifyAnalysisTile from '../components/SpotifyAnalysisTile';
---

<Layout title="SONIC_ATLAS // ANALYTIC - site(.)moss">
    <Header />
    <main class="pt-24 md:pt-8 pb-10 px-3 sm:px-4 md:px-8 max-w-[1200px] mx-auto animate-page-entry">
        <div class="border border-stone-200 bg-white/62 backdrop-blur-md p-1 relative overflow-hidden shadow-[0_18px_40px_rgba(96,70,49,0.12)]">
            <SpotifyAnalysisTile client:visible isFullPage={true} />
        </div>
    </main>
</Layout>
