---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ShoeDemoTile from '../components/ShoeDemoTile';
---

<Layout title="SHOE_ML // CLASSIFY - site(.)moss">
    <Header />
    <main class="pt-24 md:pt-8 pb-10 px-3 sm:px-4 md:px-8 max-w-[1200px] mx-auto animate-page-entry">
        <div class="mb-6 md:mb-8 border-l-4 border-[#cfb59a] pl-4">
            <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-stone-900 uppercase font-mono">Shoe_Classification.sys</h1>
            <p class="text-[10px] font-bold text-stone-600 mt-1 uppercase tracking-widest font-mono">YOLOv8_Brand_Detection // v.2.4.0</p>
        </div>
        
        <div class="border border-stone-200 bg-white/62 backdrop-blur-md p-1 relative overflow-hidden shadow-[0_18px_40px_rgba(96,70,49,0.12)]">
            <ShoeDemoTile client:visible isFullPage={true} />
        </div>
    </main>
</Layout>
